e-font-size:18px;} [data-prefix="author"] .entries {--grid-template-columns:repeat(1, minmax(0, 1fr));} [data-prefix="author"] .entry-card .entry-title {--theme-font-size:18px;} [data-prefix="search"] .entries {--grid-template-columns:repeat(1, minmax(0, 1fr));} [data-prefix="search"] .entry-card .entry-title {--theme-font-size:18px;}:root {--theme-content-vertical-spacing:50px;}}</style>
<link rel="icon" href="https://streetbiz.co.za/wp-content/uploads/2024/11/cropped-cropped-cropped-streetbiz-logo-2-1-32x32.png" sizes="32x32" />
<link rel="icon" href="https://streetbiz.co.za/wp-content/uploads/2024/11/cropped-cropped-cropped-streetbiz-logo-2-1-192x192.png" sizes="192x192" />
<link rel="apple-touch-icon" href="https://streetbiz.co.za/wp-content/uploads/2024/11/cropped-cropped-cropped-streetbiz-logo-2-1-180x180.png" />
<meta name="msapplication-TileImage" content="https://streetbiz.co.za/wp-content/uploads/2024/11/cropped-cropped-cropped-streetbiz-logo-2-1-270x270.png" />
<style id="wp-custom-css">
/* Force all headings to be bold (Base Rule) */
h1, h2, h3, h4, h5, h6 {
    font-weight: 700 !important;
}

/* Fix missing bullets in post content */
.entry-content ul, .post-content ul, .block-editor-content ul {
    list-style-type: disc !important;
    margin-left: 20px !important;
    padding-left: 20px !important;
}

/* --- LIST SPACING FIX --- */
/* This adds uniform breathing room between paragraphs and lists */
.entry-content ul, 
.entry-content ol, 
.post-content ul, 
.post-content ol,
.wp-block-list {
    margin-top: 1.5rem !important;    /* Uniform space above */
    margin-bottom: 1.5rem !important; /* Uniform space below */
}

/* Ensure list items display correctly */
.entry-content li, .post-content li {
    display: list-item !important;
    /* margin-bottom is kept standard as you are happy with internal spacing */
}

/* --- LANDING PAGE STYLES (Scoped) --- */
.nelson-landing-wrapper {
  --brand-primary: #1B4965;       /* Deep Blue */
  --brand-accent: #D4A574;        /* Gold Accent */
  --brand-secondary: #2E8B9E;     /* Teal */
  --brand-dark: #0F2C3F;          /* Dark Navy */
  --brand-light: #F5F7FA;         /* Light Background */
  --text-main: #1a1a1a;
  --text-muted: #666;
  --success-green: #2D9D78;
  
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  color: var(--text-main);
  line-height: 1.6;
  background-color: #fff;
  width: 100%;
  box-sizing: border-box;
}

.nelson-landing-wrapper * { box-sizing: border-box; }

.nelson-landing-wrapper .container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

/* HEADER */
.nelson-landing-wrapper header {
  background-color: var(--brand-dark);
  padding: 15px 0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.nelson-landing-wrapper .navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nelson-landing-wrapper .logo {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--brand-accent);
  text-decoration: none;
  letter-spacing: 1px;
}

.nelson-landing-wrapper .nav-links {
  display: flex;
  gap: 30px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.nelson-landing-wrapper .nav-links a {
  color: white;
  text-decoration: none;
  font-weight: 500;
  transition: color 0.3s ease;
}

.nelson-landing-wrapper .nav-links a:hover {
  color: var(--brand-accent);
}

/* TYPOGRAPHY */
.nelson-landing-wrapper h1, 
.nelson-landing-wrapper h2, 
.nelson-landing-wrapper h3, 
.nelson-landing-wrapper h4 {
  margin-top: 0;
  font-weight: 800;
  line-height: 1.2;
}

.nelson-landing-wrapper h1 { font-size: 3.5rem; letter-spacing: -1px; margin-bottom: 20px; color: var(--brand-dark); }
.nelson-landing-wrapper h2 { font-size: 2.5rem; margin-bottom: 20px; color: var(--brand-primary); }
.nelson-landing-wrapper h3 { font-size: 1.5rem; color: var(--brand-primary); }
.nelson-landing-wrapper p { font-size: 1.1rem; margin-bottom: 20px; }

/* BUTTONS */
.nelson-landing-wrapper .btn {
  display: inline-block;
  padding: 18px 40px;
  font-size: 1rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-decoration: none;
  border-radius: 6px;
  transition: all 0.3s ease;
  cursor: pointer;
  border: none;
}

.nelson-landing-wrapper .btn-primary {
  background-color: var(--brand-primary);
  color: white !important;
}
.nelson-landing-wrapper .btn-primary:hover {
  background-color: var(--brand-secondary);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(27, 73, 101, 0.3);
}

.nelson-landing-wrapper .btn-secondary {
  background-color: var(--success-green);
  color: white !important;
}
.nelson-landing-wrapper .btn-secondary:hover {
  background-color: #1f6b54;
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(45, 157, 120, 0.3);
}

/* HERO SECTION */
.nelson-landing-wrapper .hero-section {
  background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand-primary) 100%);
  color: white;
  padding: 120px 0;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.nelson-landing-wrapper .hero-section::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 400px;
  height: 400px;
  background-color: rgba(212, 165, 116, 0.1);
  border-radius: 50%;
  transform: translate(100px, -100px);
}

.nelson-landing-wrapper .hero-content { position: relative; z-index: 2; }
.nelson-landing-wrapper .hero-section h1 { color: white; margin-bottom: 20px; }
.nelson-landing-wrapper .hero-sub {
  font-size: 1.3rem;
  color: rgba(255, 255, 255, 0.9);
  max-width: 750px;
  margin: 0 auto 40px auto;
}

/* MANIFESTO SECTION */
.nelson-landing-wrapper .manifesto-section {
  background-color: var(--brand-dark);
  color: white;
  padding: 100px 0;
  text-align: center;
}
.nelson-landing-wrapper .manifesto-section h2 { color: var(--brand-accent); }
.nelson-landing-wrapper .manifesto-section p { color: #e0e0e0; max-width: 700px; margin: 0 auto 50px auto; font-size: 1.2rem; }

.nelson-landing-wrapper .stat-grid {
  display: flex;
  justify-content: center;
  gap: 60px;
  flex-wrap: wrap;
  margin-top: 50px;
}

.nelson-landing-wrapper .stat-item h3 {
  font-size: 3.5rem;
  color: var(--brand-accent);
  margin-bottom: 10px;
}
.nelson-landing-wrapper .stat-item span {
  text-transform: uppercase;
  font-size: 0.95rem;
  letter-spacing: 1.5px;
  font-weight: bold;
  color: #b0b0b0;
}

/* CLARITY SECTION */
.nelson-landing-wrapper .clarity-section {
  padding: 100px 0;
  background-color: var(--brand-light);
}

.nelson-landing-wrapper .clarity-header { text-align: center; max-width: 700px; margin: 0 auto 60px auto; }
.nelson-landing-wrapper .split-card-container { display: flex; flex-wrap: wrap; gap: 30px; }

.nelson-landing-wrapper .split-card {
  flex: 1;
  min-width: 300px;
  padding: 50px;
  background: white;
  border-radius: 10px;
  box-shadow: 0 8px 25px rgba(27, 73, 101, 0.08);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.nelson-landing-wrapper .split-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 15px 40px rgba(27, 73, 101, 0.15);
}

.nelson-landing-wrapper .role-badge {
  display: inline-block;
  background: var(--brand-primary);
  color: white;
  padding: 8px 16px;
  border-radius: 50px;
  font-size: 0.75rem;
  font-weight: bold;
  text-transform: uppercase;
  margin-bottom: 20px;
  letter-spacing: 1px;
}

.nelson-landing-wrapper .role-title { font-size: 1.8rem; margin-bottom: 10px; color: var(--brand-primary); }
.nelson-landing-wrapper .role-metaphor {
  font-size: 1.3rem;
  font-weight: bold;
  color: var(--brand-secondary);
  margin-bottom: 20px;
  display: block;
}

.nelson-landing-wrapper .split-card ul { color: var(--text-muted); padding-left: 20px; }
.nelson-landing-wrapper .split-card li { margin-bottom: 12px; line-height: 1.8; }

/* FRAMEWORK SECTION */
.nelson-landing-wrapper .framework-section { background-color: white; padding: 100px 0; }
.nelson-landing-wrapper .framework-header { text-align: center; margin-bottom: 60px; }
.nelson-landing-wrapper .framework-header h2 { margin-bottom: 15px; }
.nelson-landing-wrapper .framework-header p { color: var(--text-muted); font-size: 1.1rem; }

.nelson-landing-wrapper .framework-grid { display: flex; gap: 30px; flex-wrap: wrap; }
.nelson-landing-wrapper .framework-card {
  flex: 1;
  min-width: 280px;
  background: var(--brand-light);
  padding: 45px;
  border-radius: 10px;
  border-left: 5px solid var(--brand-primary);
  transition: all 0.3s ease;
}
.nelson-landing-wrapper .framework-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 12px 30px rgba(27, 73, 101, 0.12);
}

.nelson-landing-wrapper .framework-card h3 { margin-bottom: 15px; }

/* TIMELINE SECTION */
.nelson-landing-wrapper .timeline-section { padding: 100px 0; background-color: var(--brand-light); }
.nelson-landing-wrapper .timeline-header { text-align: center; margin-bottom: 60px; }
.nelson-landing-wrapper .timeline-header h2 { margin-bottom: 10px; }
.nelson-landing-wrapper .timeline-header p { color: var(--text-muted); font-size: 1.1rem; }

.nelson-landing-wrapper .timeline-steps { display: flex; justify-content: center; flex-wrap: wrap; gap: 30px; }
.nelson-landing-wrapper .timeline-step {
  flex: 1;
  min-width: 240px;
  max-width: 280px;
  background: white;
  padding: 35px;
  border-radius: 10px;
  box-shadow: 0 4px 15px rgba(27, 73, 101, 0.08);
  border-top: 4px solid var(--brand-primary);
  transition: all 0.3s ease;
}
.nelson-landing-wrapper .timeline-step:hover {
  transform: translateY(-8px);
  box-shadow: 0 12px 30px rgba(27, 73, 101, 0.15);
}
.nelson-landing-wrapper .timeline-step h4 { margin-bottom: 10px; font-size: 1.2rem; color: var(--brand-primary); }
.nelson-landing-wrapper .timeline-step span.duration { 
  display: block; font-size: 0.85rem; font-weight: bold; color: var(--brand-secondary); margin-bottom: 15px; text-transform: uppercase; letter-spacing: 1px;
}
.nelson-landing-wrapper .timeline-step p { font-size: 0.95rem; color: var(--text-muted); margin-bottom: 0; line-height: 1.7; }

/* ALUMNI SECTION */
.nelson-landing-wrapper .alumni-section {
  padding: 100px 0;
  background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-secondary) 100%);
  color: white;
}
.nelson-landing-wrapper .alumni-header { text-align: center; margin-bottom: 60px; }
.nelson-landing-wrapper .alumni-header h2 { color: var(--brand-accent); margin-bottom: 15px; }
.nelson-landing-wrapper .alumni-header p { color: rgba(255, 255, 255, 0.9); font-size: 1.1rem; }

.nelson-landing-wrapper .benefits-grid { display: flex; gap: 30px; flex-wrap: wrap; }
.nelson-landing-wrapper .benefit-card {
  flex: 1;
  min-width: 250px;
  background: rgba(255, 255, 255, 0.1);
  padding: 40px;
  border-radius: 10px;
  border: 2px solid rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
}
.nelson-landing-wrapper .benefit-card h3 { color: var(--brand-accent); margin-bottom: 15px; }
.nelson-landing-wrapper .benefit-card p { color: rgba(255, 255, 255, 0.9); }

/* APPLY SECTION */
.nelson-landing-wrapper .apply-section {
  background-color: white;
  padding: 100px 0;  text-align: center;
  border-top: 1px solid #eee;
}
.nelson-landing-wrapper .apply-header { margin-bottom: 50px; }
.nelson-landing-wrapper .apply-header h2 { margin-bottom: 15px; }
.nelson-landing-wrapper .apply-header p { color: var(--text-muted); font-size: 1.1rem; }

.nelson-landing-wrapper .form-placeholder {
  max-width: 700px;
  margin: 40px auto;
  padding: 50px;
  background: var(--brand-light);
  border: 3px dashed var(--brand-primary);
  border-radius: 10px;
  color: var(--text-muted);
}

/* CTA FOOTER */
.nelson-landing-wrapper .cta-footer {
  background-color: var(--brand-dark);
  color: white;
  padding: 60px 0;
  text-align: center;
}
.nelson-landing-wrapper .cta-footer h2 { color: var(--brand-accent); margin-bottom: 20px; }
.nelson-landing-wrapper .cta-footer p { color: rgba(255, 255, 255, 0.9); margin-bottom: 30px; }

/* RESPONSIVE */
@media (max-width: 768px) {
  .nelson-landing-wrapper h1 { font-size: 2.5rem; }
  .nelson-landing-wrapper h2 { font-size: 2rem; }
  .nelson-landing-wrapper .hero-section { padding: 80px 0; }
  .nelson-landing-wrapper .nav-links { gap: 15px; font-size: 0.9rem; }
  .nelson-landing-wrapper .split-card { padding: 30px 20px; }
  .nelson-landing-wrapper .stat-grid { gap: 30px; }
  .nelson-landing-wrapper .timeline-step { min-width: 200px; max-width: 100%; }
}
@media (max-width: 480px) {
  .nelson-landing-wrapper h1 { font-size: 2rem; }
  .nelson-landing-wrapper h2 { font-size: 1.5rem; }
  .nelson-landing-wrapper .hero-section { padding: 60px 0; }
  .nelson-landing-wrapper .nav-links { display: none; }
  .nelson-landing-wrapper .framework-card, .nelson-landing-wrapper .split-card { padding: 25px; }
}

/* --- GLOBAL HEADING STYLES --- */
h2, .entry-content h2, .wp-block-heading {
    color: #1B4965 !important;  
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif !important;
    font-weight: 800 !important;
    line-height: 1.2;
    font-size: 2.5rem !important;
    margin-bottom: 20px;
}

h3, .entry-content h3 {
    color: #1B4965 !important;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif !important;
    font-weight: 700 !important;
    font-size: 1.75rem !important;
}

@media (max-width: 768px) {
    h2, .entry-content h2, .wp-block-heading {
        font-size: 2rem !important;
    }
    h3, .entry-content h3 {
        font-size: 1.5rem !important;
    }
}

/* --- LATEST POSTS / ARCHIVE / ENTRY CARD OVERRIDE --- */
.wp-block-latest-posts h2.entry-title, 
.wp-block-latest-posts li h2,
.entry-card h2.entry-title,
.entries h2.entry-title,
.entries .entry-card h2.entry-title,
.archive h2.entry-title,
.search h2.entry-title,
.blog h2.entry-title,
.category h2.entry-title { 
    font-size: 1.25rem !important;
    line-height: 1.4;
    margin-bottom: 10px;
    font-weight: 700 !important;
}

.wp-block-latest-posts h2.entry-title a,
.entry-card h2.entry-title a,
.entries h2.entry-title a,
.archive h2.entry-title a,
.search h2.entry-title a,
.blog h2.entry-title a,
.category h2.entry-title a {
    font-size: inherit; 
    text-decoration: none;
    color: #1B4965;
}

.wp-block-latest-posts h2.entry-title a:hover,
.entry-card h2.entry-title a:hover,
.entries h2.entry-title a:hover,
.archive h2.entry-title a:hover,
.search h2.entry-title a:hover,
.blog h2.entry-title a:hover,
.category h2.entry-title a:hover {
    color: #D4A574;
    text-decoration: underline;
}
</style>
